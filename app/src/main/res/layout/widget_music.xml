<?xml version="1.0" encoding="utf-8"?>
<!-- Flat RelativeLayout — no nested containers, safest for RemoteViews -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@null"
    android:paddingLeft="6dp"
    android:paddingRight="6dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <ImageButton
        android:id="@+id/btn_prev"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:src="@drawable/ic_prev"
        android:background="@null"
        android:scaleType="fitCenter"
        android:contentDescription="Previous"/>

    <ImageButton
        android:id="@+id/btn_play_pause"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_toEndOf="@id/btn_prev"
        android:layout_centerVertical="true"
        android:layout_marginStart="6dp"
        android:src="@drawable/ic_play"
        android:background="@null"
        android:scaleType="fitCenter"
        android:contentDescription="Play/Pause"/>

    <ImageButton
        android:id="@+id/btn_next"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_toEndOf="@id/btn_play_pause"
        android:layout_centerVertical="true"
        android:layout_marginStart="6dp"
        android:src="@drawable/ic_next"
        android:background="@null"
        android:scaleType="fitCenter"
        android:contentDescription="Next"/>

    <!-- 1px vertical rule — ImageView used because plain View is not in RemoteViews supported list -->
    <ImageView
        android:id="@+id/divider"
        android:layout_width="1dp"
        android:layout_height="18dp"
        android:layout_toEndOf="@id/btn_next"
        android:layout_centerVertical="true"
        android:layout_marginStart="8dp"
        android:background="#A5A5A5"
        android:contentDescription="@null"/>

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/divider"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:text="No Media"
        android:textColor="#A5A5A5"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <TextView
        android:id="@+id/tv_artist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/divider"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/tv_title"
        android:layout_marginStart="8dp"
        android:text="---"
        android:textColor="#A5A5A5"
        android:textSize="9sp"
        android:maxLines="1"
        android:ellipsize="end"/>

</RelativeLayout>
